APP_NAME=Backend API
DEBUG=false
API_V1_PREFIX=/api/v1
APP_PORT=8000

POSTGRES_USER=backend
POSTGRES_PASSWORD=backend
POSTGRES_DB=backend
POSTGRES_PORT=5432

# Used when running FastAPI directly on the host with `uv run`.
# Docker Compose injects a container-only DATABASE_URL that uses host `postgres`.
DATABASE_URL=postgresql+asyncpg://backend:backend@localhost:5432/backend
